        "@angular/build": "21.0.5",
        "@angular/cli": "21.2.0",
        "@angular/compiler-cli": "21.0.8",
        "@angular/language-service": "21.0.8",
        "@angular/localize": "21.0.8",
        "@capacitor/cli": "^6.2.0",
        "@eslint/js": "^9.8.0",
        "@nx/angular": "22.3.3",
        "@nx/devkit": "22.3.3",
