{
    "name": "@silver/source",
    "version": "0.0.0",
    "license": "MIT",
    "engines": {
        "node": ">=22.0.0"
    },
    "scripts": {
        "serve:exercises-db": "node apps/tabata-ai/scripts/serve-exercises-db.mjs",
        "start:tabata-ai": "concurrently \"node apps/tabata-ai/scripts/serve-exercises-db.mjs\" \"nx serve tabata-ai\" --names \"exercises-db,tabata-ai\"",
        "build-localize:tabata-ai": "nx build tabata-ai  --localize",
        "build-run:tabata-ai": "npx http-server dist/apps/tabata-ai",
        "start:vehicles-app": "nx serve vehicles-app",
        "server:vehicles-app": "nx run vehicles-server:server",
        "start:notes-app": "nx serve notes-app",
        "server:notes-app": "nx run notes-server:server",
        "xi18n:tabata-ai": "nx run tabata-ai:extract-i18n",
        "format": "nx format:write",
        "test": "nx run-many -t test",
        "test:tabata": "nx run-many -t test --projects=tag:scope:tabata",
        "test:vehicles": "nx run-many -t test --projects=tag:scope:vehicles",
        "test:notes": "nx run-many -t test --projects=tag:scope:notes",
        "test:shared": "nx run-many -t test --projects=tag:scope:shared",
        "e2e:tabata-ai": "nx e2e tabata-ai-e2e",
        "cap:sync:tabata-ai": "nx build tabata-ai --configuration=development && cd apps/tabata-ai && npx cap sync",
        "cap:android:tabata-ai": "nx build tabata-ai --configuration=development && cd apps/tabata-ai && npx cap sync android && powershell -ExecutionPolicy Bypass -File scripts/open-android-studio.ps1",
        "cap:ios:tabata-ai": "nx build tabata-ai --configuration=development && cd apps/tabata-ai && npx cap sync ios && npx cap open ios",
        "cap:run:android:tabata-ai": "nx build tabata-ai --configuration=development && cd apps/tabata-ai && npx cap sync android && powershell -ExecutionPolicy Bypass -File scripts/run-android.ps1",
        "cap:run:ios:tabata-ai": "nx build tabata-ai --configuration=development && cd apps/tabata-ai && npx cap sync ios && npx cap run ios",
        "build-apk:tabata-ai": "nx build tabata-ai --configuration=development && cd apps/tabata-ai && npx cap sync android && powershell -ExecutionPolicy Bypass -File scripts/build-apk.ps1",
        "cap:icons:tabata-ai": "cd apps/tabata-ai && node scripts/generate-app-icon.mjs",
        "cap:live:android:tabata-ai": "cd apps/tabata-ai && npx cap run android --livereload --external",
        "cap:live:ios:tabata-ai": "cd apps/tabata-ai && npx cap run ios --livereload --external",
        "postinstall": "patch-package"
    },
    "private": true,
    "overrides": {
        "rollup": "^4.59.0"
    },
    "dependencies": {
        "@angular/animations": "21.2.7",
        "@angular/cdk": "21.2.5",
        "@angular/common": "21.2.7",
        "@angular/compiler": "21.2.7",
        "@angular/core": "21.2.7",
        "@angular/fire": "21.0.0-rc.0",
        "@angular/forms": "21.2.7",
        "@angular/material": "21.2.5",
        "@angular/platform-browser": "21.2.7",
        "@angular/platform-browser-dynamic": "21.2.7",
        "@angular/router": "21.2.7",
        "@capacitor-community/keep-awake": "^8.0.0",
        "@capacitor/android": "^6.0.0",
        "@capacitor/app": "^6.0.0",
        "@capacitor/core": "^6.2.0",
        "@capacitor/haptics": "^6.0.0",
        "@capacitor/ios": "^6.0.0",
        "@capacitor/keyboard": "^6.0.0",
        "@capacitor/status-bar": "^6.0.0",
        "@genkit-ai/googleai": "^1.28.0",
        "@ionic/angular": "^8.0.0",
        "@ngrx/effects": "21.0.0",
        "@ngrx/operators": "21.0.0",
        "@ngrx/signals": "21.0.0",
        "@ngrx/store": "21.0.0",
        "@ngrx/store-devtools": "21.0.0",
        "body-parser": "^1.20.4",
        "express": "^5.1.0",
        "firebase": "^12.10.0",
        "genkit": "^1.30.1",
        "ionicons": "^7.0.0",
        "rxjs": "~7.8.0",
        "zone.js": "0.16.0"
    },
    "devDependencies": {
        "@angular-devkit/build-angular": "21.2.6",
        "@angular-devkit/core": "21.2.6",
        "@angular-devkit/schematics": "21.2.6",
        "@angular-eslint/schematics": "21.2.0",
        "@angular/build": "21.2.6",
        "@angular/cli": "21.2.6",
        "@angular/compiler-cli": "21.2.7",
        "@angular/language-service": "21.2.7",
        "@angular/localize": "21.2.7",
        "@capacitor/assets": "^3.0.5",
        "@capacitor/cli": "^8.2.0",
        "@eslint/js": "^9.8.0",
        "@nx/angular": "22.6.4",
        "@nx/devkit": "22.6.4",
        "@nx/eslint": "22.6.4",
        "@nx/eslint-plugin": "22.6.4",
        "@nx/jest": "22.6.4",
        "@nx/js": "22.6.4",
        "@nx/playwright": "22.6.4",
        "@nx/web": "22.6.4",
        "@nx/workspace": "22.6.4",
        "@nxext/capacitor": "21.0.0",
        "@nxext/ionic-angular": "21.0.0",
        "@playwright/test": "^1.36.0",
        "@schematics/angular": "21.2.6",
        "@swc-node/register": "1.11.1",
        "@swc/core": "1.15.5",
        "@swc/helpers": "0.5.18",
        "@types/body-parser": "^1.19.6",
        "@types/express": "^5.0.3",
        "@types/jest": "30.0.0",
        "@types/node": "20.19.0",
        "@typescript-eslint/utils": "^8.40.0",
        "angular-eslint": "21.2.0",
        "autoprefixer": "^10.4.0",
        "concurrently": "^9.2.1",
        "eslint": "^9.28.0",
        "eslint-config-prettier": "10.0.0",
        "eslint-plugin-playwright": "^1.6.2",
        "jest": "30.2.0",
        "jest-environment-jsdom": "30.2.0",
        "jest-preset-angular": "16.0.0",
        "jest-util": "30.2.0",
        "json-server": "^0.17.4",
        "nx": "22.6.4",
        "patch-package": "^8.0.1",
        "postcss": "^8.4.5",
        "prettier": "~3.6.2",
        "rollup": "^4.59.0",
        "source-map-explorer": "^2.5.3",
        "tailwindcss": "^3.0.2",
        "ts-jest": "^29.4.0",
