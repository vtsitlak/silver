{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Tabata AI: Chrome",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:4200",
            "webRoot": "${workspaceFolder}/apps/tabata-ai/src",
            "preLaunchTask": "Tabata AI: Start Dev Server"
        },
        {
            "name": "Tabata AI: Edge",
            "type": "msedge",
            "request": "launch",
            "url": "http://localhost:4200",
            "webRoot": "${workspaceFolder}/apps/tabata-ai/src",
            "preLaunchTask": "Tabata AI: Start Dev Server"
        },
        {
            "name": "Tabata AI: Attach to Chrome",
            "type": "chrome",
            "request": "attach",
            "port": 9222,
            "webRoot": "${workspaceFolder}/apps/tabata-ai/src"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Debug books-club-api with Nx",
            "runtimeExecutable": "npx",
            "runtimeArgs": ["nx", "serve", "books-club-api"],
            "env": {
                "NODE_OPTIONS": "--inspect=9229"
            },
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "skipFiles": ["<node_internals>/**"],
            "sourceMaps": true,
            "outFiles": ["${workspaceFolder}/apps/books-club-api/dist/**/*.(m|c|)js", "!**/node_modules/**"]
        }
    ],
    "compounds": [
        {
            "name": "Tabata AI: Full Stack Debug",
            "configurations": ["Tabata AI: Chrome"]
        }
    ]
}
